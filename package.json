{
  "name": "tower-hunter-game",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "validate": "tsx scripts/validate.ts && npm run typecheck",
    "seed": "tsx scripts/seed.ts",
    "db:check": "tsx scripts/db-check.ts",
    "dev": "node scripts/dev.mjs",
    "dev:web": "vite",
    "dev:api": "tsx watch src/server/index.ts",
    "build": "vite build",
    "generate:audio": "node scripts/generateAudioAssets.mjs",
    "generate:sprites": "node scripts/generateCharacterSheets.mjs",
    "export:nav": "node scripts/buildNavButtonSvgs.mjs && node scripts/buildBagIconSvg.mjs && node scripts/buildShopIconSvg.mjs",
    "export:equip-slots": "node scripts/buildEquipmentSlotSvgs.mjs",
    "export:icons": "node scripts/buildNavButtonSvgs.mjs && node scripts/buildBagIconSvg.mjs && node scripts/buildShopIconSvg.mjs && node scripts/buildBookIconSvg.mjs && node scripts/buildEquipmentSlotSvgs.mjs && node scripts/exportImperialIcons.mjs",
    "export:hero": "node scripts/buildHeroPortraitSvg.mjs",
    "fetch:audio": "node scripts/fetchStudioAudio.mjs",
    "preview": "vite preview",
    "start": "tsx src/server/index.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "dotenv": "^17.4.2",
    "hono": "^4.7.4",
    "pg": "^8.13.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "adm-zip": "^0.6.0",
    "ffmpeg-static": "^5.3.0",
    "mcp-game-helper": "github:xhulz/mcp-game-helper",
    "sharp": "^0.35.3",
    "tsx": "^4.19.3",
    "typescript": "^5.7.0",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^0.21.1"
  }
}
